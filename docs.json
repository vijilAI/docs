{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Vijil",
  "logo": {
    "dark": "/logo/vijil-logo-dark.svg",
    "light": "/logo/vijil-logo-light.svg"
  },
  "description": "Harden during development, validate before deployment, defend in runtime, and continuously improve agents with reinforcement learning.",
  "colors": {
    "primary": "#DE1616",
    "light": "#FF4444",
    "dark": "#0247A9"
  },
  "css": "/styles.css",
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "api": {
    "openapi": ["openapi/api.json"],
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "all"
    },
    "url": "full",
    "examples": {
      "languages": ["curl", "python", "javascript", "go"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    }
  },
  "redirects": [
    {
      "source": "/get-started/welcome",
      "destination": "/concepts/what-is-vijil"
    },
    {
      "source": "/get-started/quickstart",
      "destination": "/developer-guide/getting-started/quickstart"
    },
    {
      "source": "/get-started/overview",
      "destination": "/owner-guide/getting-started/introduction"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Concepts",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "concepts/welcome",
              {
                "group": "Platform",
                "icon": "box",
                "expanded": true,
                "pages": [
                  "concepts/platform/console",
                  "concepts/platform/diamond",
                  "concepts/platform/dome"
                ]
              }
            ]
          },
          {
            "group": "Trust Score",
