                  "concepts/trust-score/reliability",
                  "concepts/trust-score/safety",
                  "concepts/trust-score/security"
                ]
              }
            ]
          },
          {
            "group": "Evaluation",
            "pages": [
              "concepts/evaluation-components/introduction",
              {
                "group": "Trust Score Components",
                "icon": "handshake",
